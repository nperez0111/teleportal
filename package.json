{
  "name": "teleportal",
  "version": "0.0.4",
  "private": false,
  "description": "A storage, transport & runtime agnostic Y.js server/provider. Built on web primitives, supports subdocs, and handles everything without in-memory storage. Perfect for collaborative apps! 🚀",
  "keywords": [
    "e2ee",
    "protocol",
    "provider",
    "runtime",
    "server",
    "storage",
    "subdocs",
    "transport",
    "yjs"
  ],
  "license": "MPL-2.0",
  "repository": "nperez0111/teleportal",
  "workspaces": [
    "playground",
    "examples/*",
    "docs"
  ],
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/lib/index.mjs",
  "types": "./dist/lib/index.d.mts",
  "exports": {
    ".": "./dist/lib/index.mjs",
    "./storage": "./dist/storage/index.mjs",
    "./http": "./dist/http/index.mjs",
    "./protocol": "./dist/lib/protocol/index.mjs",
    "./protocols/milestone": "./dist/protocols/milestone/index.mjs",
    "./protocols/file": "./dist/protocols/file/index.mjs",
    "./protocols/attribution": "./dist/protocols/attribution/index.mjs",
    "./protocols/key-registry": "./dist/protocols/key-registry/index.mjs",
    "./protocol/encryption": "./dist/lib/protocol/encryption/index.mjs",
    "./providers": "./dist/providers/index.mjs",
    "./transports/redis": "./dist/transports/redis/index.mjs",
    "./transports/nats": "./dist/transports/nats/index.mjs",
    "./transports/rate-limiter": "./dist/transports/rate-limiter/index.mjs",
    "./transports": "./dist/transports/index.mjs",
    "./websocket-server": "./dist/websocket-server/index.mjs",
    "./server": "./dist/server/index.mjs",
    "./monitoring": "./dist/monitoring/index.mjs",
    "./encryption-key": "./dist/encryption-key/index.mjs",
    "./token": "./dist/token/index.mjs",
    "./merkle-tree": "./dist/merkle-tree/index.mjs",
    "./devtools": "./dist/devtools/index.mjs",
    "./agent": "./dist/agent/index.mjs",
    "./attribution": "./dist/lib/attribution/index.mjs",
    "./rpc": "./dist/lib/rpc/index.mjs"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "build:demo": "cd ./playground && bun run build",
    "lint": "vp check",
    "lint:fix": "vp check --fix",
    "prepack": "bun run build",
    "dev": "PORT=1235 bun run --watch ./playground/bun/server.ts",
    "dev:encrypted": "PORT=1234 bun run --watch ./playground/bun/encrypted-server.ts",
    "release": "bun run test && changelogen --release && npm publish && git push --follow-tags",
    "test": "bun run test:types && bun test --dots",
    "test:types": "vp check --no-fmt",
    "bench": "bun test ./benchmarks/ --timeout 120000",
    "bench:storage": "bun test ./benchmarks/storage.bench.test.ts --timeout 120000",
    "bench:server": "bun test ./benchmarks/server.bench.test.ts --timeout 120000",
    "bench:sync": "bun test ./benchmarks/sync.bench.test.ts --timeout 120000",
    "bench:protocol": "bun test ./benchmarks/protocol.bench.test.ts --timeout 120000",
    "bench:file": "bun test ./benchmarks/file.bench.test.ts --timeout 120000",
    "bench:client": "bun test ./benchmarks/client.bench.test.ts --timeout 120000",
    "bench:attribution": "bun test ./benchmarks/attribution.bench.test.ts --timeout 120000",
    "bench:rate-limiter": "bun test ./benchmarks/rate-limiter.bench.test.ts --timeout 120000",
    "bench:pubsub": "bun test ./benchmarks/pubsub-batching.bench.test.ts --timeout 120000",
    "bench:integration": "bun test ./benchmarks/server-integration.bench.test.ts --timeout 120000",
    "bench:tiered": "bun test ./benchmarks/tiered-storage.bench.test.ts --timeout 120000"
  },
  "dependencies": {
    "@logtape/logtape": "2.2.1",
    "@tanstack/devtools-event-client": "0.5.0",
    "hookable": "6.1.1",
    "jose": "6.2.3",
    "lib0": "0.2.117",
    "y-protocols": "1.0.7",
    "yjs": "13.6.31"
  },
  "devDependencies": {
    "@nats-io/transport-node": "3.4.0",
    "@types/bun": "1.3.14",
    "bun-plugin-tailwind": "0.1.2",
    "changelogen": "0.6.2",
    "crossws": "0.4.6",
    "eventsource": "4.1.0",
    "ioredis": "5.11.1",
    "msw": "2.14.6",
    "srvx": "0.11.17",
    "tinybench": "6.0.2",
    "unstorage": "1.17.5",
    "vite-plus": "0.2.1"
  },
  "peerDependencies": {
    "@nats-io/transport-node": "^3.2.0",
    "@standard-schema/spec": "1.1.0",
    "crossws": "^0.4.3",
    "ioredis": "^5.8.2",
    "unstorage": "^1.17.2"
  },
  "peerDependenciesMeta": {
    "@nats-io/transport-node": {
      "optional": true
    },
    "@standard-schema/spec": {
      "optional": true
    },
    "crossws": {
      "optional": true
    },
    "ioredis": {
      "optional": true
    },
    "unstorage": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "bun@1.3.8",
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
