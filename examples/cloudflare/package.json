{
  "name": "teleportal-cloudflare-example",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build:client": "bun build src/client.ts --outdir public --target browser --format esm --minify",
    "dev": "bun run build:client && wrangler dev",
    "deploy": "bun run build:client && wrangler deploy",
    "e2e": "bun run scripts/e2e.ts"
  },
  "dependencies": {
    "crossws": "^0.4.9",
    "prosemirror-example-setup": "^1.2.3",
    "prosemirror-keymap": "^1.2.2",
    "prosemirror-model": "^1.25.0",
    "prosemirror-schema-basic": "^1.2.4",
    "prosemirror-state": "^1.4.3",
    "prosemirror-view": "^1.38.0",
    "y-prosemirror": "1.3.7",
    "y-protocols": "^1.0.7",
    "yjs": "^13.6.31"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260115.0",
    "eventsource": "^4.1.0",
    "wrangler": "^4.61.1"
  }
}
